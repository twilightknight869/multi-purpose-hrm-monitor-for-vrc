<Window x:Class="HRMMonitor.Views.UpdateAlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available"
        Width="340" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Topmost="True" ResizeMode="NoResize">

    <Border CornerRadius="12"
            Background="#FF0f0f18"
            BorderBrush="#FF2e2e48"
            BorderThickness="1"
            Padding="20,18">

        <StackPanel>

            <!-- Title -->
            <TextBlock Text="⬆  UPDATE AVAILABLE"
                       FontSize="13" FontWeight="Bold"
                       Foreground="#FFe03535"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="SubLbl"
                       Text="A new version of HRM Monitor is ready."
                       FontSize="11"
                       Foreground="#FF888899"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>

            <!-- Countdown -->
            <Border Background="#FF080010" CornerRadius="6"
                    Margin="0,14,0,0" Padding="10,8">
                <TextBlock x:Name="CountdownLbl"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="#FF4488cc"
                           HorizontalAlignment="Center"
                           Text="Opening browser in 10 s…"/>
            </Border>

            <!-- Buttons -->
            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="NowBtn"
                        Content="Open Now"
                        Click="NowBtn_Click"/>

                <Button Grid.Column="2" x:Name="SkipBtn"
                        Content="Skip"
                        Foreground="#FF555566"
                        Click="SkipBtn_Click"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>
