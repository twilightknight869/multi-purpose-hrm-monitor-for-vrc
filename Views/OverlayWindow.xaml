<Window x:Class="HRMMonitor.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HRM Overlay"
        Width="220" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonDown="Window_MouseRightButtonDown">

    <Window.Resources>
        <!-- Heart scale transform, animated from code-behind -->
        <ScaleTransform x:Key="HeartScale" ScaleX="1" ScaleY="1"/>
    </Window.Resources>

    <Border x:Name="RootBorder"
            CornerRadius="14"
            Background="#CC0d0d1a"
            BorderBrush="#FF2e2e48"
            BorderThickness="1"
            Padding="14,12">

        <StackPanel>

            <!-- ── Heart + BPM row ─────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Pulsing heart -->
                <TextBlock x:Name="HeartLbl"
                           Grid.Column="0"
                           Text="♥"
                           FontFamily="Segoe UI Emoji"
                           FontSize="28"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="#FFe03535"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <ScaleTransform x:Name="HeartScaleTransform" ScaleX="1" ScaleY="1"/>
                    </TextBlock.RenderTransform>
                </TextBlock>

                <!-- BPM value -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="BpmLbl"
                               Text="--"
                               FontFamily="Consolas"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="#FFe03535"
                               LineHeight="38"/>
                    <TextBlock x:Name="TierLbl"
                               Text="waiting…"
                               FontFamily="Consolas"
                               FontSize="10"
                               Foreground="#FF555566"
                               Margin="2,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ── BPM graph ───────────────────────────────── -->
            <Border Margin="0,10,0,0" Height="40" CornerRadius="4"
                    Background="#FF080010" ClipToBounds="True">
                <Canvas x:Name="GraphCanvas" Height="40"/>
            </Border>

            <!-- ── Dev badge ───────────────────────────────── -->
            <Border x:Name="DevBadge" Visibility="Collapsed"
                    Background="#22e03535" CornerRadius="4"
                    Padding="6,2" Margin="0,8,0,0">
                <TextBlock x:Name="DevLbl"
                           FontFamily="Consolas" FontSize="9"
                           Foreground="#FFe03535"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- ── Track info (optional Spotify) ──────────── -->
            <TextBlock x:Name="TrackLbl"
                       Margin="0,8,0,0"
                       FontFamily="Consolas"
                       FontSize="10"
                       Foreground="#FF4466aa"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       Visibility="Collapsed"/>

        </StackPanel>
    </Border>
</Window>
