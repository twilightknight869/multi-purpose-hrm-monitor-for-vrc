<Window x:Class="HRMMonitor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HRM Monitor" Height="680" Width="580"
        MinHeight="580" MinWidth="520"
        Background="#FF0f0f18" Foreground="#FFe0e0e0"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="#FF888899"/>
            <Setter Property="Margin"       Value="0,14,0,6"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#FF444455"/>
            <Setter Property="Margin"     Value="0,3,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width"  Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>   <!-- header -->
            <RowDefinition Height="*"/>    <!-- tabs -->
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#FF0d0d1a" BorderBrush="#FF2e2e48" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="♥ " FontFamily="Segoe UI Emoji" FontSize="16" Foreground="#FFe03535" VerticalAlignment="Center"/>
                    <TextBlock Text="HRM MONITOR" FontSize="14" FontWeight="Bold" Foreground="#FFe03535"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,0,0">
                    <Ellipse x:Name="ConnDot" Style="{StaticResource StatusDot}" Fill="#FF333344"/>
                    <TextBlock x:Name="ConnLbl" Text="disconnected" Foreground="#FF444455" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Main tabs ─────────────────────────────────────────── -->
        <TabControl Grid.Row="1" x:Name="MainTabs" SelectionChanged="MainTabs_SelectionChanged">

            <!-- ══ BROADCASTER ════════════════════════════════════ -->
            <TabItem Header="📡  Broadcaster">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="12,0,12,0">
                    <StackPanel Margin="0,8,0,16">

                        <!-- Pulsoid -->
                        <GroupBox Header="Pulsoid Token">
                            <StackPanel>
                                <TextBlock Style="{StaticResource HintText}"
                                           Text="Get yours at pulsoid.net → Settings → Integrations → Manual connection"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <PasswordBox x:Name="TokenBox" Grid.Column="0" Height="32"
                                                 PasswordChanged="TokenBox_Changed"/>
                                    <Button Grid.Column="1" Content="Show" Width="70" Margin="6,0,0,0"
                                            Click="ShowToken_Click" x:Name="ShowTokenBtn"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- OSC -->
                        <GroupBox Header="VRChat OSC">
                            <StackPanel>
                                <CheckBox x:Name="OscCheck" Content="Enable OSC (avatar parameters)"
                                          Checked="OscCheck_Changed" Unchecked="OscCheck_Changed"/>
                                <CheckBox x:Name="ChatboxCheck" Content="Send to VRChat chatbox"
                                          Margin="0,6,0,0"
                                          Checked="ChatboxCheck_Changed" Unchecked="ChatboxCheck_Changed"/>
                                <CheckBox x:Name="UnicodeEmojiCheck"
                                          Content="Unicode symbols (♥ ♡ ❤ ♪ ▲ ▼)"
                                          Margin="0,6,0,0"
                                          Checked="UnicodeEmoji_Changed" Unchecked="UnicodeEmoji_Changed"/>
                                <CheckBox x:Name="InvisibleChatboxCheck"
                                          Content="Invisible background mode (Premium)"
                                          Margin="0,6,0,0" Visibility="Collapsed"
                                          Checked="InvisibleChatbox_Changed" Unchecked="InvisibleChatbox_Changed"/>

                                <TextBlock Text="CHATBOX TEMPLATE" Style="{StaticResource SectionHeader}"/>
                                <TextBox x:Name="ChatboxTemplate" Height="30"
                                         TextChanged="ChatboxTemplate_Changed"/>
                                <TextBlock Style="{StaticResource HintText}"
                                           Text="{}{icon} {bpm} BPM [{bar}]  |  tokens: {tier} {pronoun} {track} {artist}"/>

                                <TextBlock Text="PREVIEW" Style="{StaticResource SectionHeader}"/>
                                <Border Background="#FF0d0d1a" CornerRadius="6" Padding="10,7">
                                    <TextBlock x:Name="ChatboxPreview" FontFamily="Consolas" FontSize="12"
                                               Foreground="#FF88aacc" TextWrapping="Wrap"/>
                                </Border>

                                <Expander Header="OSC address settings" Margin="0,10,0,0" Foreground="#FF888899">
                                    <StackPanel Margin="0,8,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="IP" VerticalAlignment="Center" Foreground="#FF888899"/>
                                            <TextBox   Grid.Column="1" x:Name="OscIpBox" Height="28" TextChanged="OscAddr_Changed"/>
                                            <TextBlock Grid.Column="2" Text="Port" VerticalAlignment="Center" Foreground="#FF888899" Margin="8,0,0,0"/>
                                            <TextBox   Grid.Column="3" x:Name="OscPortBox" Height="28" TextChanged="OscAddr_Changed"/>
                                        </Grid>
                                        <TextBlock Text="HR Parameter" Foreground="#FF888899" Margin="0,8,0,3"/>
                                        <TextBox x:Name="HrParamBox" Height="28" TextChanged="OscAddr_Changed"/>
                                        <TextBlock Text="HRPercent Parameter" Foreground="#FF888899" Margin="0,6,0,3"/>
                                        <TextBox x:Name="PctParamBox" Height="28" TextChanged="OscAddr_Changed"/>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </GroupBox>

                        <!-- Friend sharing (host) -->
                        <GroupBox Header="Friend HR Sharing">
                            <StackPanel>
                                <CheckBox x:Name="ShareCheck" Content="Broadcast my heart rate"
                                          Checked="ShareCheck_Changed" Unchecked="ShareCheck_Changed"/>
                                <TextBlock Style="{StaticResource HintText}" Margin="0,4,0,0"
                                           Text="Uses ntfy.sh — free, no account needed. Share your Room Code with your partner."/>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="ROOM CODE" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="RoomCodeLbl" FontFamily="Consolas" FontSize="26"
                                                   FontWeight="Bold" Foreground="#FFe03535"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="New Code" VerticalAlignment="Bottom"
                                            Click="NewCode_Click"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- Spotify (collapsed by default) -->
                        <Expander Header="🎵  Spotify Now Playing" Margin="0,4,0,0" Foreground="#FF888899">
                            <Border Background="#FF0d0d1a" Padding="8,8,8,4" Margin="0,4,0,0" CornerRadius="4">
                                <StackPanel>
                                    <CheckBox x:Name="SpotifyCheck" Content="Enable Spotify integration"
                                              Checked="SpotifyCheck_Changed" Unchecked="SpotifyCheck_Changed"/>
                                    <TextBlock Text="Client ID" Style="{StaticResource SectionHeader}"/>
                                    <TextBox x:Name="SpClientId" Height="28" TextChanged="SpotifyText_Changed"/>
                                    <TextBlock Text="Client Secret" Style="{StaticResource SectionHeader}"/>
                                    <PasswordBox x:Name="SpClientSecret" Height="28" PasswordChanged="SpotifySecret_Changed"/>
                                    <TextBlock Text="Redirect URI" Style="{StaticResource SectionHeader}"/>
                                    <TextBox x:Name="SpRedirectUri" Height="28" TextChanged="SpotifyText_Changed"/>
                                    <Button Content="Authorize Spotify" Margin="0,10,0,4"
                                            HorizontalAlignment="Left" Click="SpotifyAuth_Click"/>
                                </StackPanel>
                            </Border>
                        </Expander>

                        <!-- SteamVR (collapsed by default) -->
                        <GroupBox Header="SteamVR Wrist Overlay (Apple Watch style)">
                            <StackPanel>
                                <CheckBox x:Name="SteamVrCheck" Content="Enable wrist overlay (start SteamVR first)"
                                          Checked="SteamVrCheck_Changed" Unchecked="SteamVrCheck_Changed"/>
                                <CheckBox x:Name="VrRaiseToViewCheck" Content="Raise to view (show info panel when wrist raised)"
                                          Margin="0,8,0,0"
                                          Checked="VrRaiseToView_Changed" Unchecked="VrRaiseToView_Changed"/>

                                <TextBlock Text="HAND" Style="{StaticResource SectionHeader}"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="VrLeftHand"  Content="Left hand"  GroupName="VrHand"
                                                 Margin="0,0,16,0" Checked="VrHand_Changed"/>
                                    <RadioButton x:Name="VrRightHand" Content="Right hand" GroupName="VrHand"
                                                 Checked="VrHand_Changed"/>
                                </StackPanel>

                                <TextBlock Text="WATCH SIZE" Style="{StaticResource SectionHeader}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="VrSizeSlider" Grid.Column="0"
                                            Minimum="0.04" Maximum="0.16" SmallChange="0.01"
                                            VerticalAlignment="Center"
                                            ValueChanged="VrSize_Changed"/>
                                    <TextBlock x:Name="VrSizeLbl" Grid.Column="1" VerticalAlignment="Center"
                                               HorizontalAlignment="Right" Foreground="#FFe03535" FontSize="11"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- Start button -->
                        <Button x:Name="StartBtn" Content="▶   START OVERLAY"
                                Height="44" FontSize="14" FontWeight="Bold"
                                Margin="0,8,0,0" Click="Start_Click"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══ VIEWER ══════════════════════════════════════════ -->
            <TabItem Header="👁  Viewer">
                <StackPanel Margin="12,16,12,16">

                    <TextBlock Text="Watch your partner's heart rate" FontSize="16" FontWeight="Bold"
                               Foreground="#FFe03535" HorizontalAlignment="Center"/>
                    <TextBlock Text="Ask your partner for their Room Code. No accounts or port forwarding needed."
                               HorizontalAlignment="Center" Foreground="#FF888899" FontSize="12"
                               Margin="0,6,0,20" TextWrapping="Wrap" TextAlignment="Center"/>

                    <GroupBox Header="Room Code">
                        <StackPanel>
                            <TextBox x:Name="ViewerCodeBox" Height="54" FontFamily="Consolas"
                                     FontSize="26" FontWeight="Bold" TextAlignment="Center"
                                     MaxLength="6" CharacterCasing="Upper"
                                     Foreground="#FFe03535"
                                     Background="#FF080010"
                                     TextChanged="ViewerCode_Changed"/>
                            <TextBlock Text="6 characters — given to you by your partner"
                                       Style="{StaticResource HintText}" HorizontalAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Partner HR → VRChat avatar OSC -->
                    <GroupBox Header="Partner HR in VRChat (Couples OSC)" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HintText}"
                                       Text="Send your partner's live BPM to your VRChat avatar so both HRs show at once."/>
                            <CheckBox x:Name="FriendHrOscCheck" Content="Enable partner HR on my avatar"
                                      Margin="0,8,0,0"
                                      Checked="FriendHrOsc_Changed" Unchecked="FriendHrOsc_Changed"/>
                            <TextBlock Text="PARTNER HR PARAMETER" Style="{StaticResource SectionHeader}"/>
                            <TextBox x:Name="FriendHrParamBox" Height="28"
                                     TextChanged="FriendHrParam_Changed"/>
                            <TextBlock Style="{StaticResource HintText}"
                                       Text="e.g. /avatar/parameters/HerHR  or  /avatar/parameters/HisHR"/>
                        </StackPanel>
                    </GroupBox>

                    <Button Content="💑   CONNECT &amp; WATCH" Height="44" FontSize="14" FontWeight="Bold"
                            Margin="0,12,0,0" Click="Watch_Click"/>

                    <!-- Group Watch (horror game mode) -->
                    <GroupBox Header="Group Watch — Horror Game Mode" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HintText}"
                                       Text="Watch up to 5 friends at once. Enter each room code on its own line. All HRs show in your VR wrist panel."/>
                            <TextBlock Text="FRIEND ROOM CODES (one per line)" Style="{StaticResource SectionHeader}"/>
                            <TextBox x:Name="GroupCodesBox" Height="90" AcceptsReturn="True"
                                     FontFamily="Consolas" FontSize="13"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="GroupCodes_Changed"/>
                            <Button Content="👻  WATCH GROUP" Height="38" FontSize="13" FontWeight="Bold"
                                    Margin="0,10,0,0" Click="WatchGroup_Click"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- ══ SETTINGS ════════════════════════════════════════ -->
            <TabItem Header="⚙  Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,0,12,0">
                    <StackPanel Margin="0,8,0,16">

                        <!-- License -->
                        <GroupBox Header="License">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="LicenseKeyBox" Grid.Column="0" Height="30"
                                             FontFamily="Consolas"
                                             TextChanged="LicenseKey_Changed"/>
                                    <Button Grid.Column="1" Content="Activate" Width="80" Margin="6,0,0,0"
                                            Click="LicenseActivate_Click"/>
                                </Grid>
                                <Border x:Name="LicenseBadge" CornerRadius="4" Padding="8,4"
                                        Margin="0,8,0,0" Background="#FF0d0d1a">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="LicenseDot" Width="8" Height="8"
                                                 Fill="#FF333344" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="LicenseLbl"
                                                   Text="Enter your license key above"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="#FF555566" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="FreeTimeLbl"
                                           Margin="0,6,0,0"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#FFffaa33"
                                           Visibility="Collapsed"/>
                                <!-- Dev tag toggle — only visible for slots 1-3 -->
                                <CheckBox x:Name="DevTagCheck"
                                          Content="Show DEVELOPER tag in overlay + chatbox"
                                          Margin="0,8,0,0" Visibility="Collapsed"
                                          Checked="DevTag_Changed" Unchecked="DevTag_Changed"/>

                                <TextBlock Style="{StaticResource HintText}" Margin="0,6,0,0"
                                           Text="Get a key: join our Discord and use /mykey"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="BPM Thresholds">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="HIGH BPM" Style="{StaticResource SectionHeader}"/>
                                    <TextBox x:Name="BpmHighBox" Height="28" TextChanged="BpmThresh_Changed"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="MED BPM" Style="{StaticResource SectionHeader}"/>
                                    <TextBox x:Name="BpmMedBox" Height="28" TextChanged="BpmThresh_Changed"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Chatbox Pronoun">
                            <StackPanel>
                                <TextBlock Style="{StaticResource HintText}"
                                           Text="Used as {pronoun} in your chatbox template — e.g. 'His HR: {bpm} BPM'"/>
                                <TextBlock Text="LABEL" Style="{StaticResource SectionHeader}"/>
                                <ComboBox x:Name="PronounBox" Height="28"
                                          SelectionChanged="Pronoun_Changed">
                                    <!-- Standard pronouns -->
                                    <ComboBoxItem Content="My"/>
                                    <ComboBoxItem Content="His"/>
                                    <ComboBoxItem Content="Her"/>
                                    <ComboBoxItem Content="Their"/>
                                    <ComboBoxItem Content="Our"/>
                                    <!-- Neopronouns -->
                                    <ComboBoxItem Content="Xe/Xem"/>
                                    <ComboBoxItem Content="Ze/Hir"/>
                                    <ComboBoxItem Content="Ey/Em"/>
                                    <ComboBoxItem Content="Ve/Ver"/>
                                    <ComboBoxItem Content="Per/Per"/>
                                    <ComboBoxItem Content="It/Its"/>
                                    <ComboBoxItem Content="Fae/Faer"/>
                                    <ComboBoxItem Content="Ae/Aer"/>
                                    <ComboBoxItem Content="One's"/>
                                </ComboBox>
                                <TextBlock Style="{StaticResource HintText}"
                                           Text="Use {pronoun} in your chatbox template"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Overlay">
                            <StackPanel>
                                <TextBlock Text="OPACITY" Style="{StaticResource SectionHeader}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="OpacitySlider" Grid.Column="0" Minimum="0.3" Maximum="1.0"
                                            SmallChange="0.05" LargeChange="0.1" VerticalAlignment="Center"
                                            ValueChanged="Opacity_Changed"/>
                                    <TextBlock x:Name="OpacityLbl" Grid.Column="1" VerticalAlignment="Center"
                                               HorizontalAlignment="Right" Foreground="#FFe03535" FontSize="12"/>
                                </Grid>
                                <CheckBox x:Name="ShakeCheck" Content="Screen shake on high BPM"
                                          Margin="0,10,0,0"
                                          Checked="ShakeCheck_Changed" Unchecked="ShakeCheck_Changed"/>
                                <CheckBox x:Name="SoundCheck" Content="Heartbeat sound effect"
                                          Margin="0,6,0,0"
                                          Checked="SoundCheck_Changed" Unchecked="SoundCheck_Changed"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Live status panel (like Python version) -->
                        <GroupBox Header="Status">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <!-- Pulsoid -->
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Ellipse x:Name="StatusPulsoidDot" Width="8" Height="8" Fill="#FF333344"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="StatusPulsoidLbl" Text="Pulsoid: disconnected"
                                                       FontFamily="Consolas" FontSize="11" Foreground="#FF555566"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- OSC -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Ellipse x:Name="StatusOscDot" Width="8" Height="8" Fill="#FF333344"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="StatusOscLbl" Text="OSC: off"
                                                       FontFamily="Consolas" FontSize="11" Foreground="#FF555566"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- Chatbox -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Ellipse x:Name="StatusChatboxDot" Width="8" Height="8" Fill="#FF333344"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="StatusChatboxLbl" Text="Chatbox: off"
                                                       FontFamily="Consolas" FontSize="11" Foreground="#FF555566"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <!-- Sharing -->
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Ellipse x:Name="StatusSharingDot" Width="8" Height="8" Fill="#FF333344"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="StatusSharingLbl" Text="Sharing: off"
                                                       FontFamily="Consolas" FontSize="11" Foreground="#FF555566"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- Spotify -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Ellipse x:Name="StatusSpotifyDot" Width="8" Height="8" Fill="#FF333344"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="StatusSpotifyLbl" Text="Spotify: off"
                                                       FontFamily="Consolas" FontSize="11" Foreground="#FF555566"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- License -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Ellipse x:Name="StatusLicenseDot" Width="8" Height="8" Fill="#FF333344"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="StatusLicenseLbl" Text="License: free"
                                                       FontFamily="Consolas" FontSize="11" Foreground="#FF555566"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="About">
                            <StackPanel>
                                <TextBlock Text="HRM Monitor v3.0.0" Foreground="#FFe03535" FontWeight="Bold"/>
                                <TextBlock Text="Made by CRIMSON" Foreground="#FF888899" Margin="0,4,0,0"/>
                                <TextBlock Text="Discord: crimsondreamz" Foreground="#FF888899"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- UI Customization (premium/dev only) -->
                        <GroupBox x:Name="CustomizeGroup" Header="UI Customization" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="ACCENT COLOR" Style="{StaticResource SectionHeader}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button x:Name="AccentRedBtn"    Content="●" Foreground="#FFe03535" Width="32" Height="32" Margin="0,0,6,0" Click="Accent_Click" Tag="#FFe03535"/>
                                    <Button x:Name="AccentPurpleBtn" Content="●" Foreground="#FF9b59b6" Width="32" Height="32" Margin="0,0,6,0" Click="Accent_Click" Tag="#FF9b59b6"/>
                                    <Button x:Name="AccentBlueBtn"   Content="●" Foreground="#FF3498db" Width="32" Height="32" Margin="0,0,6,0" Click="Accent_Click" Tag="#FF3498db"/>
                                    <Button x:Name="AccentGreenBtn"  Content="●" Foreground="#FF2ecc71" Width="32" Height="32" Margin="0,0,6,0" Click="Accent_Click" Tag="#FF2ecc71"/>
                                    <Button x:Name="AccentPinkBtn"   Content="●" Foreground="#FFe91e8c" Width="32" Height="32" Margin="0,0,6,0" Click="Accent_Click" Tag="#FFe91e8c"/>
                                    <Button x:Name="AccentOrangeBtn" Content="●" Foreground="#FFff6b35" Width="32" Height="32" Margin="0,0,6,0" Click="Accent_Click" Tag="#FFff6b35"/>
                                    <Button x:Name="AccentWhiteBtn"  Content="●" Foreground="#FFe0e0e0" Width="32" Height="32" Click="Accent_Click" Tag="#FFe0e0e0"/>
                                </StackPanel>

                                <TextBlock Text="THEME" Style="{StaticResource SectionHeader}"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="ThemeDark"  Content="Dark"  GroupName="Theme" Margin="0,0,16,0" Checked="Theme_Changed"/>
                                    <RadioButton x:Name="ThemeDarker" Content="Darker" GroupName="Theme" Margin="0,0,16,0" Checked="Theme_Changed"/>
                                    <RadioButton x:Name="ThemeOled"  Content="OLED"  GroupName="Theme" Checked="Theme_Changed"/>
                                </StackPanel>

                                <TextBlock x:Name="AccentPreview" Margin="0,10,0,0"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#FFe03535"
                                           Text="♥  Preview — HRM MONITOR  ●  connected"/>
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══ HELP ════════════════════════════════════════════ -->
            <TabItem Header="❓  Help">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,0,12,0">
                    <StackPanel Margin="0,8,0,24">

                        <GroupBox Header="Quick Start">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#FFe0e0e0" LineHeight="20">
                                    <Run FontWeight="Bold" Foreground="#FFe03535">1. Get your Pulsoid token</Run>
                                    <LineBreak/>
                                    <Run>Go to pulsoid.net → Settings → Integrations → Manual connection. Copy the token and paste it in the Broadcaster tab.</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run FontWeight="Bold" Foreground="#FFe03535">2. Enable OSC in VRChat</Run>
                                    <LineBreak/>
                                    <Run>In VRChat: Action Menu → Options → OSC → Enable. This lets HRM Monitor talk to your avatar and chatbox.</Run>
                                    <LineBreak/><LineBreak/>
                                    <Run FontWeight="Bold" Foreground="#FFe03535">3. Click START OVERLAY</Run>
                                    <LineBreak/>
                                    <Run>The floating overlay appears. The dot in the top-right turns green when Pulsoid connects.</Run>
                                </TextBlock>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Chatbox Template Tokens">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#FFe0e0e0" LineHeight="22" FontFamily="Consolas" FontSize="11">
                                    <Run Foreground="#FFe03535">{bpm}</Run><Run>      — Live heart rate number</Run><LineBreak/>
                                    <Run Foreground="#FFe03535">{bar}</Run><Run>      — Progress bar (=====-----)</Run><LineBreak/>
                                    <Run Foreground="#FFe03535">{tier}</Run><Run>     — LOW / MED / HIGH</Run><LineBreak/>
                                    <Run Foreground="#FFe03535">{icon}</Run><Run>     — ♡ / ♥~ / ❤!! based on tier</Run><LineBreak/>
                                    <Run Foreground="#FFe03535">{pronoun}</Run><Run>  — His / Her / Their / Our etc.</Run><LineBreak/>
                                    <Run Foreground="#FFe03535">{track}</Run><Run>    — Spotify track name</Run><LineBreak/>
                                    <Run Foreground="#FFe03535">{artist}</Run><Run>   — Spotify artist name</Run>
                                </TextBlock>
                                <Border Background="#FF0d0d1a" CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
                                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#FF4488cc" TextWrapping="Wrap"
                                               Text="{}{icon} {bpm} BPM  ( {tier} )&#x0a;[{bar}]{track}"/>
                                </Border>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Friend HR Sharing">
                            <TextBlock TextWrapping="Wrap" Foreground="#FFe0e0e0" LineHeight="20">
                                <Run FontWeight="Bold">Host (you):</Run><Run> Broadcaster tab → tick Broadcast my heart rate → Start Overlay. Share the Room Code.</Run>
                                <LineBreak/><LineBreak/>
                                <Run FontWeight="Bold">Viewer (friend):</Run><Run> Viewer tab → enter the Room Code → Connect and Watch. A floating window shows the host's BPM live.</Run>
                                <LineBreak/><LineBreak/>
                                <Run FontWeight="Bold">Couples OSC:</Run><Run> Viewer tab → enable Partner HR on my avatar → set the parameter name (e.g. /avatar/parameters/HerHR). Your avatar gets both HRs at once.</Run>
                                <LineBreak/><LineBreak/>
                                <Run FontWeight="Bold">Group / Horror mode:</Run><Run> Viewer tab → Group Watch section → enter up to 5 room codes one per line → Watch Group. All friends' HRs appear in your VR wrist panel.</Run>
                            </TextBlock>
                        </GroupBox>

                        <GroupBox Header="VR Wrist Overlay (SteamVR)">
                            <TextBlock TextWrapping="Wrap" Foreground="#FFe0e0e0" LineHeight="20">
                                <Run>Start SteamVR first, then tick Enable wrist overlay in the Broadcaster tab. The overlay anchors to your chosen hand like an Apple Watch.</Run>
                                <LineBreak/><LineBreak/>
                                <Run FontWeight="Bold">Raise to view:</Run><Run> Lift your wrist like checking a watch — an expanded panel fades in showing BPM, status, and group HRs.</Run>
                                <LineBreak/><LineBreak/>
                                <Run FontWeight="Bold">Hand switching:</Run><Run> Settings → SteamVR section → Left / Right hand radio buttons. Changes instantly.</Run>
                                <LineBreak/><LineBreak/>
                                <Run FontWeight="Bold">Watch size:</Run><Run> Adjust the size slider (4 cm – 16 cm) to match your preference.</Run>
                            </TextBlock>
                        </GroupBox>

                        <GroupBox Header="Overlay Tips">
                            <TextBlock TextWrapping="Wrap" Foreground="#FFe0e0e0" LineHeight="20">
                                <Run FontWeight="Bold">Drag:</Run><Run> Left-click and drag the overlay to reposition it anywhere on screen.</Run>
                                <LineBreak/>
                                <Run FontWeight="Bold">Always on top:</Run><Run> Right-click the overlay to toggle always-on-top. Border flashes orange when it is off.</Run>
                                <LineBreak/>
                                <Run FontWeight="Bold">Heartbeat sound:</Run><Run> Settings → Overlay → Heartbeat sound effect checkbox. Volume follows your Windows volume.</Run>
                                <LineBreak/>
                                <Run FontWeight="Bold">Screen shake:</Run><Run> Shakes when BPM hits the HIGH threshold. Disable in Settings → Overlay.</Run>
                            </TextBlock>
                        </GroupBox>

                        <GroupBox Header="Spotify Integration">
                            <TextBlock TextWrapping="Wrap" Foreground="#FFe0e0e0" LineHeight="20">
                                <Run>1. Create a Spotify app at developer.spotify.com → Dashboard → Create App.</Run>
                                <LineBreak/>
                                <Run>2. Set Redirect URI to http://127.0.0.1:8888/callback in the Spotify app settings.</Run>
                                <LineBreak/>
                                <Run>3. Copy Client ID and Client Secret into HRM Monitor → Broadcaster → Spotify.</Run>
                                <LineBreak/>
                                <Run>4. Click Authorize Spotify — a browser window opens. Log in and approve.</Run>
                                <LineBreak/>
                                <Run>5. Add {track} and/or {artist} to your chatbox template to show the current song.</Run>
                                <LineBreak/>
                                <Run>Your token is saved — you only need to authorize once per install.</Run>
                            </TextBlock>
                        </GroupBox>

                        <GroupBox Header="Safety &amp; Transparency">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#FF44cc77" FontWeight="Bold"
                                           Text="This software is open source and safe to use." Margin="0,0,0,6"/>
                                <TextBlock TextWrapping="Wrap" Foreground="#FFe0e0e0" LineHeight="20">
                                    <Run FontWeight="Bold">What it connects to:</Run><LineBreak/>
                                    <Run Foreground="#FF4488cc">• pulsoid.net</Run><Run> — reads your heart rate (your token only)</Run><LineBreak/>
                                    <Run Foreground="#FF4488cc">• 127.0.0.1:9000</Run><Run> — local OSC to VRChat (stays on your PC)</Run><LineBreak/>
                                    <Run Foreground="#FF4488cc">• railway.app relay</Run><Run> — room code + BPM number for friend sharing</Run><LineBreak/>
                                    <Run Foreground="#FF4488cc">• api.github.com</Run><Run> — checks for updates (version string only)</Run><LineBreak/>
                                    <LineBreak/>
                                    <Run FontWeight="Bold">What it does NOT do:</Run><LineBreak/>
                                    <Run Foreground="#FFff4444">✗</Run><Run> Access your files or documents</Run><LineBreak/>
                                    <Run Foreground="#FFff4444">✗</Run><Run> Collect or transmit personal data</Run><LineBreak/>
                                    <Run Foreground="#FFff4444">✗</Run><Run> Install drivers, services, or startup entries</Run><LineBreak/>
                                    <Run Foreground="#FFff4444">✗</Run><Run> Run in the background unless you launch it</Run><LineBreak/>
                                    <LineBreak/>
                                    <Run FontWeight="Bold">Settings location:</Run>
                                    <Run> Windows Registry → HKCU\Software\HRMMonitor\v2</Run><LineBreak/>
                                    <Run FontWeight="Bold">Source code:</Run>
                                    <Run> github.com/twilightknight869/Multi-Purpose-HRM-Monitor-For-VRC (v2 branch)</Run>
                                </TextBlock>
                                <Button Content="View Source Code on GitHub" Margin="0,10,0,0"
                                        HorizontalAlignment="Left" Click="ViewSource_Click"/>
                                <Button Content="Scan on VirusTotal" Margin="0,6,0,0"
                                        HorizontalAlignment="Left" Click="VirusTotal_Click"/>
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
