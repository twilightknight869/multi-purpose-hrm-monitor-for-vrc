<Window x:Class="HRMMonitor.Views.ViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HRM Viewer"
        Width="200" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Closing="Window_Closing">

    <Border CornerRadius="14"
            Background="#CC0d0d1a"
            BorderBrush="#FF2e2e48"
            BorderThickness="1"
            Padding="14,12">

        <StackPanel>

            <!-- ── Friend label + close ────────────────────── -->
            <Grid>
                <TextBlock x:Name="FriendLbl"
                           FontFamily="Consolas"
                           FontSize="10"
                           Foreground="#FF555566"
                           VerticalAlignment="Center"
                           Text="Watching friend…"/>
                <Button x:Name="CloseBtn"
                        Content="✕"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="20" Height="20"
                        Padding="0"
                        FontSize="10"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#FF444455"
                        Click="CloseBtn_Click"
                        Cursor="Hand"/>
            </Grid>

            <!-- ── Heart + BPM ─────────────────────────────── -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="HeartLbl"
                           Grid.Column="0"
                           Text="♥"
                           FontFamily="Segoe UI Emoji"
                           FontSize="26"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="#FF4466aa"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <ScaleTransform x:Name="HeartScale" ScaleX="1" ScaleY="1"/>
                    </TextBlock.RenderTransform>
                </TextBlock>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="BpmLbl"
                               Text="--"
                               FontFamily="Consolas"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="#FF4466aa"/>
                    <TextBlock x:Name="StatusLbl"
                               Text="connecting…"
                               FontFamily="Consolas"
                               FontSize="10"
                               Foreground="#FF444455"/>
                </StackPanel>
            </Grid>

            <!-- ── Connection status dot ───────────────────── -->
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Ellipse x:Name="ConnDot" Width="7" Height="7"
                         Fill="#FF333344"
                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="ConnLbl"
                           Text="disconnected"
                           FontFamily="Consolas"
                           FontSize="10"
                           Foreground="#FF444455"
                           VerticalAlignment="Center"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
