# Copy this to .env and fill in your values

# Discord bot token (from discord.com/developers/applications)
DISCORD_TOKEN=your-bot-token-here

# Your bot's Application ID (from Discord developer portal)
CLIENT_ID=your-client-id-here

# Your Discord server ID (right-click server → Copy Server ID)
GUILD_ID=your-guild-id-here

# Role ID that can use admin commands (right-click role → Copy Role ID)
# Leave blank to only allow server Administrators
ADMIN_ROLE_ID=

# Channel ID to log key issuances/revocations
LOG_CHANNEL_ID=

# Secret header the C# app must send — make this long and random
API_SECRET=change-this-to-something-long-and-random-123456

# Your CashApp $tag shown in /mykey instructions
CASHAPP_TAG=$YourCashTag

# Price shown in /mykey instructions
PRICE=$5.00/month

# Port for the verification API (Railway sets this automatically)
PORT=3000
